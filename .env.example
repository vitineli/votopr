# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VotoPR
# Opcional: sem este token, o mapa usa OpenStreetMap como base.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=electoral-uploads

# Database
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Import worker
IMPORT_BATCH_SIZE=20000
IMPORT_ERROR_SAMPLE_SIZE=250
IMPORT_TARGET_STATE=PR
MAP_GEOJSON_CACHE_SECONDS=60
